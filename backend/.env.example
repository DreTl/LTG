# ─────────────────────────────────────────────────────────────
# LTG backend environment configuration
# Copy this file to `.env` for local use, or set these as real
# environment variables in your production host.
# ─────────────────────────────────────────────────────────────

# Flask secret key — MUST be a long random value in production.
SECRET_KEY=change-me-to-a-long-random-secret

# Real database. Use PostgreSQL in production.
# Examples:
#   postgresql://user:password@host:5432/ltg
#   postgres://user:password@host:5432/ltg   (auto-normalized)
# If left unset, the app falls back to a local SQLite file (dev only).
DATABASE_URL=postgresql://ltg_user:ltg_password@localhost:5432/ltg

# Connection pool tuning (PostgreSQL only).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=280

# Server runtime.
HOST=0.0.0.0
PORT=5002
FLASK_DEBUG=false

# Schema management:
#   true  -> auto-create tables on boot (simple deploys / first run)
#   false -> manage schema with `flask db upgrade` (recommended for prod)
RUN_DB_CREATE_ALL=true

# Comma-separated allowed origins for the API, or * for any.
# In production set this to your frontend domain(s).
CORS_ORIGINS=*

# Optional: persist uploaded images on a mounted volume.
# UPLOAD_FOLDER=/var/data/ltg/uploads
